#   cp .env.example .env

# ── PostgreSQL
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=163.239.77.77        # VDI 배포: DB 서버 IP
DB_PORT=8000
DB_NAME=seoganpyo

# ── JWT
SECRET_KEY=change-me-to-a-long-random-string

# ── 관리자 API
ADMIN_SECRET_KEY=change-me-in-production

# ── 이메일 발송 (Gmail SMTP)
SENDER_EMAIL=your_gmail@gmail.com
SENDER_PASSWORD=your_gmail_app_password  # Gmail 앱 비밀번호 (2단계 인증)

# ── 프론트엔드 API URL
# 로컬: http://localhost:8080
NEXT_PUBLIC_API_URL=http://163.239.77.77:8080
# NEXT_PUBLIC_API_URL=http://localhost:8080

# ── 백엔드 URL (회원가입 승인 링크 생성에 사용)
# 로컬: http://localhost:8080
BACKEND_URL=http://163.239.77.77:8080

# ── 로그 레벨 (백엔드)
LOG_LEVEL=INFO

# ── Google Gemini API (포트폴리오 AI 평가용)
# https://aistudio.google.com 에서 발급
GEMINI_API_KEY=MYKEY
GEMINI_MODEL=gemini-2.5-flash

# ── Grafana 관리자 계정 (관측 스택 사용 시)
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ── Grafana URL (admin 페이지 iframe 임베드용)
# 로컬: http://localhost:3001
# 팀 서버: http://163.239.77.77:3001
NEXT_PUBLIC_GRAFANA_URL=http://localhost:3001
