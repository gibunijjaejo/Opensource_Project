FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV TZ=Asia/Seoul

WORKDIR /app

# ── dev 전용 — docker CLI 설치 스킵 ──
# admin_assistant.get_container_status는 docker CLI 필요하지만,
# 로컬 개발에선 거의 사용 안 함. 필요하면 prod Dockerfile 사용 (또는 호스트 docker.sock 마운트로 대체).

# 종속성 설치
COPY requirements.txt .
RUN pip install --no-cache-dir --timeout 300 --retries 5 -r requirements.txt

# 애플리케이션 코드 (compose에서 volume mount하므로 사실상 의미 없음)
COPY ./app ./app
COPY ./static ./static
COPY ./data ./data

EXPOSE 8000
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
